[Unit]
Description=Flask App6 - Zgrzewanie - podział na procesy
After=network.target

[Service]
User=konrad
Group=konrad
WorkingDirectory=/home/konrad/apps/app6/zg4_web
Environment="PATH=/home/konrad/apps/app6/zg4_web/venv/bin"
Environment="FLASK_APP=run.py"
Environment="FLASK_ENV=production"
ExecStart=/home/konrad/apps/app6/zg4_web/venv/bin/gunicorn -b 127.0.0.1:5006 run:app
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
