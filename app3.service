[Unit]
Description=Flask App3 - Kalkulator Farb dla BOM
After=network.target

[Service]
User=konrad
Group=konrad
WorkingDirectory=/home/konrad/apps/app3/mala_web
Environment="PATH=/home/konrad/apps/app3/mala_web/venv/bin"
Environment="FLASK_APP=app.py"
Environment="FLASK_ENV=production"
ExecStart=/home/konrad/apps/app3/mala_web/venv/bin/gunicorn -b 127.0.0.1:5003 app:app
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
